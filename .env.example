# Kalshi API credentials (production)
# Generate at https://kalshi.com after account creation; Settings -> API.
# IMPORTANT: paste the PRIVATE KEY content as a single line with \n escapes,
# OR set KALSHI_PRIVATE_KEY_PATH to point to a PEM file outside the repo.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENV=demo  # demo | prod -- start with demo

# Kalshi demo credentials (separate keypair from prod)
KALSHI_DEMO_API_KEY_ID=
KALSHI_DEMO_PRIVATE_KEY_PATH=

# Open-Meteo, Iowa State NWS - no auth required for current archives

# Discord webhook for daily P&L and alert pings (Phase 4+)
DISCORD_WEBHOOK_URL=

# Operator capital cap (USD). Code reads this and refuses orders above it.
# Operator-authorized ceiling is $100; $25 is the recommended initial
# deployment per the post-Phase-1 critic. Raise toward $100 once a strategy
# validates. Going above $100 requires explicit operator authorization
# AND a code change (config.py `le=` bound).
CAPITAL_CAP_USD=25
